HeaderFilterRegex: .*/(src|tests)/.*\.(h|hpp)

Checks: >
  bugprone-*,
  cert-*,
  -cert-err58-cpp,
  clang-analyzer-*,
  concurrency-*,
  cppcoreguidelines-*,
  hicpp-*,
  -hicpp-signed-bitwise,
  misc-*,
  -misc-no-recursion,
  modernize-*,
  performance-*,
  portability-*,
  -portability-avoid-pragma-once,
  readability-*,
  -readability-identifier-length,
